{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:datamesh:schemas:canonical.workorder.snapshot.v1",
  "title": "Canonical WorkOrder Snapshot v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["eventId", "eventTime", "topic", "workOrder"],
  "properties": {
    "eventId": { "type": "string", "minLength": 1 },
    "eventTime": { "type": "string", "format": "date-time" },
    "topic": { "type": "string", "const": "maintenance.workorder.snapshot.v1" },
    "workOrder": {
      "type": "object",
      "additionalProperties": false,
      "required": ["workOrderId", "assetId", "title", "status", "deleted", "assetSummary"],
      "properties": {
        "workOrderId": { "type": "string", "minLength": 1 },
        "assetId": { "type": "string", "minLength": 1 },
        "title": { "type": "string", "minLength": 1 },
        "description": { "type": ["string", "null"] },
        "status": { "type": "string", "minLength": 1 },
        "priority": { "type": ["string", "null"] },
        "deleted": { "type": "boolean" },
        "updatedAt": { "type": ["string", "null"], "format": "date-time" },
        "assetSummary": {
          "type": "object",
          "additionalProperties": false,
          "required": ["assetId", "name"],
          "properties": {
            "assetId": { "type": "string", "minLength": 1 },
            "name": { "type": "string", "minLength": 1 },
            "type": { "type": ["string", "null"] },
            "location": { "type": ["string", "null"] },
            "status": { "type": ["string", "null"] },
            "href": { "type": ["string", "null"], "format": "uri-reference" }
          }
        }
      }
    }
  }
}
